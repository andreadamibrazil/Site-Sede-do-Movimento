# NextAuth (OBRIGATÓRIO — gere com: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://sededomovimento.art

# Google OAuth (NextAuth sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Sheets (Pauta)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Gemini AI (free tier — rotação automática, ~1.500 req/dia por chave)
# AIzaSy... keys: usar sem header (query param ?key=)
# AQ....   keys: precisam de header x-goog-api-key (tratado automaticamente pelo código)
# Ordem de uso: KEY → KEY_2 → ... → KEY_10 (pula em caso de 429)
GOOGLE_AI_KEY=
GOOGLE_AI_KEY_2=
GOOGLE_AI_KEY_3=
GOOGLE_AI_KEY_4=
GOOGLE_AI_KEY_5=
GOOGLE_AI_KEY_6=
GOOGLE_AI_KEY_7=
GOOGLE_AI_KEY_8=
GOOGLE_AI_KEY_9=
GOOGLE_AI_KEY_10=

# YouTube (Pauta — busca de vídeos virais)
YOUTUBE_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DocuSeal (assinatura digital self-hosted)
DOCUSEAL_URL=http://sede-docuseal.brazilsouth.azurecontainer.io:3000
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=

